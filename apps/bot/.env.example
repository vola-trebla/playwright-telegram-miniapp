# Copy to apps/bot/.env. Get a token from @BotFather.
BOT_TOKEN=

# Public HTTPS URL of the Mini App — Telegram requires HTTPS for web_app buttons.
# Local dev: expose apps/backend via a tunnel, e.g.
#   cloudflared tunnel --url http://localhost:3000
# or use the Telegram test environment (it allows HTTP/IP for Mini Apps).
WEBAPP_URL=http://localhost:3000
