{
  "name": "playwright-telegram-miniapp-e2e",
  "version": "1.0.0",
  "description": "Playwright + TypeScript E2E/API suite for a Telegram Mini App marketplace",
  "type": "module",
  "scripts": {
    "test": "playwright test",

    "test:api": "playwright test --project=api",
    "test:web": "playwright test --project=web",

    "test:smoke": "playwright test --grep @smoke",
    "test:security": "playwright test tests/api/security-edge.spec.ts tests/api/init-data.spec.ts",
    "test:ws": "playwright test tests/api/websocket.spec.ts",
    "test:race": "playwright test tests/api/market.spec.ts",
    "test:cross": "playwright test tests/api/cross-system.spec.ts",

    "test:seq": "playwright test --project=web --workers=1 --headed",
    "test:api:seq": "playwright test --project=api --workers=1",

    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --project=web --headed",
    "test:debug": "PWDEBUG=1 playwright test --workers=1",
    "report": "playwright show-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:serve": "allure serve allure-results",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs,json,md,yml,yaml}": "prettier --write"
  },
  "keywords": [
    "playwright",
    "typescript",
    "qa",
    "automation",
    "e2e",
    "api"
  ],
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/node": "^25.9.1",
    "@types/ws": "^8.18.1",
    "allure-commandline": "^2.42.0",
    "allure-js-commons": "^3.9.0",
    "allure-playwright": "^3.9.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.1",
    "eslint-plugin-playwright": "^2.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.5.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.24.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  }
}
