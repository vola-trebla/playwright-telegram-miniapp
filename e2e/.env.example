# Copy to e2e/.env and adjust per environment. Never commit real secrets.

# Base URL of the MRKT-like backend under test (apps/backend).
MARKET_URL=http://localhost:3000

# Bot token the test backend (run with DEV_MODE=false) validates initData against.
# Tests sign initData with this same token, so a valid signature is accepted.
TEST_BOT_TOKEN=test-bot-token
